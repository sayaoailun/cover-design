          "bottom_y": 635,
          "font_size": 38,
          "min_font_size": 10,
          "max_font_size": 42,
          "font_name": "msyh.ttc",
          "fallback_font": "arial.ttf",
          "font_weight": "Bold",
          "spacing_base": 1.5,
          "size_map": [
            {"min_chars": 1, "max_chars": 6, "size": 42},
            {"min_chars": 7, "max_chars": 11, "size": 35},
            {"min_chars": 12, "max_chars": 16, "size": 31},
            {"min_chars": 17, "max_chars": 24, "size": 18},
            {"min_chars": 25, "max_chars": 999, "size": 10}
          ],
          "column_gap_ratio": 2.0,
          "max_height": 420,
          "max_columns": 1,
          "orientation": "vertical"
        },
        "subtitle": {
          "x": 690,
          "bottom_y": 635,
          "font_size": 30,
          "min_font_size": 10,
          "max_font_size": 34,
          "font_name": "msyh.ttc",
          "fallback_font": "arial.ttf",
          "font_weight": "Regular",
          "spacing_base": 1.5,
          "size_map": [
            {"min_chars": 1, "max_chars": 7, "size": 36},
            {"min_chars": 8, "max_chars": 12, "size": 30},
            {"min_chars": 13, "max_chars": 16, "size": 24},
            {"min_chars": 17, "max_chars": 999, "size": 15}
          ],
