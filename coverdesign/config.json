{
  "canvas": {
    "width": 800,
    "height": 800
  },
  "paths": {
    "excel_file": "ISBN.xlsx",
    "cover_dir": "cover",
    "materials_dir": "materials",
    "output_dir": "Output",
    "logo_image": "materials/公司logo.png",
    "watermark_image": "materials/水印.png"
  },
  "version_map": {
    "英文": "英文.png",
    "中文": "中文.png",
    "德文": "德文.png",
    "韩文": "韩文.png",
    "西班牙文": "西班牙文.png",
